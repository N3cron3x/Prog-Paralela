{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build (nvcc + OpenMP)",
            "type": "shell",
            "command": "nvcc",
            "args": [
                "-O2",
                "-Xcompiler", "-fopenmp",
                "-arch=sm_75",
                "-o", "vector_add",
                "vector_add.cu",
                "-lgomp", "-lm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "./vector_add",
            "dependsOn": "Build (nvcc + OpenMP)",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
